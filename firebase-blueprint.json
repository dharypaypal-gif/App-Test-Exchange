{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL" },
        "bio": { "type": "string", "description": "User's biography" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the app" },
        "points": { "type": "number", "description": "User's earned points" },
        "isNewUser": { "type": "boolean", "description": "Flag for showing welcome wizard" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
